{
  "version": "2026-07-20",
  "notes": "Platform-specific PyTorch install profiles for PixEagle setup-pytorch.sh",
  "python_compatibility": {
    "minimum": "3.9",
    "maximum": "3.13",
    "basis": "The pinned PyTorch 2.6.0 artifact set provides CPython wheels through 3.13."
  },
  "profiles": {
    "linux_x86_cuda12": {
      "supported": true,
      "description": "Linux x86_64 with NVIDIA GPU (CUDA 12.x)",
      "install_method": "index",
      "index_url": "https://download.pytorch.org/whl/cu124",
      "packages": {
        "torch": "2.6.0",
        "torchvision": "0.21.0",
        "torchaudio": "2.6.0"
      },
      "verify": {
        "require_cuda": true,
        "require_mps": false
      },
      "prereqs": {
        "apt_packages": []
      }
    },
    "linux_x86_cuda11": {
      "supported": true,
      "description": "Linux x86_64 with NVIDIA GPU (CUDA 11.x)",
