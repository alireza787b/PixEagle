      "packages": {
        "torch": "2.6.0",
        "torchvision": "0.21.0",
        "torchaudio": "2.6.0"
      },
      "verify": {
        "require_cuda": true,
        "require_mps": false
      },
      "prereqs": {
        "apt_packages": []
      }
    },
    "linux_cpu": {
