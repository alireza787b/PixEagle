    "jetson_jp62": {
      "supported": false,
      "description": "NVIDIA Jetson JetPack 6.2.x (verified wheel override required)",
      "install_method": "wheels",
      "python_tag": "cp310",
      "wheels": {
        "torch": "",
        "torchvision": "",
        "torchaudio": ""
      },
      "wheel_sha256": {
        "torch": "",
        "torchvision": "",
