      "supported": true,
      "description": "macOS Intel (CPU-only)",
      "install_method": "pypi",
      "packages": {
        "torch": "2.6.0",
        "torchvision": "0.21.0",
        "torchaudio": "2.6.0"
      },
      "verify": {
        "require_cuda": false,
        "require_mps": false
      },
