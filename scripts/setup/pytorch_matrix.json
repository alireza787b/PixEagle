        "apt_packages": []
      }
    },
    "macos_arm64_mps": {
      "supported": true,
      "description": "macOS Apple Silicon (MPS acceleration)",
      "install_method": "pypi",
      "packages": {
        "torch": "2.6.0",
        "torchvision": "0.21.0",
        "torchaudio": "2.6.0"
      },
      "verify": {
        "require_cuda": false,
