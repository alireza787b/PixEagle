Dry run: PixEagle setup profile qgc_direct_media
  - Streaming.API_EXPOSURE_MODE: 'local_only' -> 'trusted_lan_legacy'
  - Streaming.HTTP_STREAM_HOST: '127.0.0.1' -> '127.0.0.1'
  - Streaming.HTTP_STREAM_PORT: 5077 -> 5077
  - Streaming.API_CORS_ALLOWED_ORIGINS: ['http://127.0.0.1:3040', 'http://localhost:3040', 'http://127.0.0.1:5077', 'http://localhost:5077'] -> ['https://pixeagle.example']
  - Streaming.API_ALLOWED_HOSTS: [] -> ['pixeagle.example:443']
  - Streaming.API_AUTH_MODE: 'local_compat' -> 'machine_bearer'
  - Streaming.API_SYSTEM_RESTART_POLICY: 'local_only' -> 'local_only'
  - Streaming.API_BEARER_TOKEN_FILE: '' -> '/tmp/pixeagle-handoff-qgc-tokens.json'
  - Streaming.API_SECURITY_AUDIT_ENABLED: True -> True
